{
  "name": "@a2ui/local-gallery-v09",
  "private": true,
  "version": "0.1.0",
  "description": "A2UI Local Gallery (Agentless)",
  "type": "module",
  "scripts": {
    "sync-specs": "node scripts/sync-specs.js",
    "dev": "yarn sync-specs && vite",
    "build": "wireit",
    "serve": "vite preview"
  },
  "dependencies": {
    "@a2ui/lit": "workspace:*",
    "@a2ui/markdown-it": "workspace:*",
    "@a2ui/web_core": "workspace:*",
    "@lit-labs/signals": "^0.1.3",
    "@lit/context": "^1.1.4",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vite": "^7.1.11"
  },
  "wireit": {
    "build": {
      "command": "yarn sync-specs && tsc && vite build",
      "dependencies": [
        "../../../../renderers/lit:build",
        "../../../../renderers/markdown/markdown-it:build",
        "../../../../renderers/web_core:build"
      ],
      "files": [
        "src/**/*",
        "index.html",
        "tsconfig.json",
        "vite.config.*",
        "scripts/**/*"
      ],
      "output": [
        "dist/"
      ]
    }
  }
}
