{
  "name": "@a2ui/react-shell",
  "private": true,
  "version": "0.8.1",
  "description": "A2UI React Shell Demo",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "wireit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.4",
    "@a2ui/react": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "5.9.3",
    "vite": "^6.0.0"
  },
  "wireit": {
    "build": {
      "command": "tsc -b && vite build",
      "dependencies": [
        "../../../../renderers/react:build"
      ],
      "files": [
        "src/**/*",
        "index.html",
        "tsconfig.json",
        "vite.config.*"
      ],
      "output": [
        "dist/"
      ]
    }
  }
}
