root = Card(main-column)
main-column = Column([header, value, trend-row])
header = Row([metric-icon, metric-name], null, "center")
metric-icon = Icon($/icon)
metric-name = Text($/metricName, "caption")
value = Text(formatCurrency($/value, "USD"), "h1")
trend-row = Row([trend-icon, trend-text], null, "center")
trend-icon = Icon($/trendIcon)
trend-text = Text(formatString("+${/trendPercent}% from last month"), "body")
