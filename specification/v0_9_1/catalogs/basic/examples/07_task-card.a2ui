root = Card(main-row)
main-row = Row([status-checkbox, content, priority], null, "start")
status-checkbox = CheckBox("", $/completed)
content = Column([title, description, meta-row])
title = Text($/title, "h3")
description = Text($/description, "body")
meta-row = Row([due-date-input, project], null, "center")
due-date-input = DateTimeInput($/dueDate, true, true, null, null, "Due")
project = Text($/project, "caption")
priority = Icon($/priorityIcon)
